# ─── Secrets / env ─────────────────────────────────────
# .env holds real API keys — keep it out of the repo. Use .env.example as a template.
.env
.env.local
*.env

# ─── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ─── Node / Next.js (frontend) ─────────────────────────
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── ML artifacts (regenerated by the training pipeline) ─
ml/models/*.joblib
ml/models/*.json
*.joblib

# ─── Local data / logs (populated at runtime, not source) ─
data/raw/*
data/processed/*
data/historical/*
logs/*
!**/.gitkeep

# ─── Editor / OS ───────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# ─── Claude Code local files ───────────────────────────
.claude/
