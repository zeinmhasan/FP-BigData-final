# Copy this file to `.env` and fill in your own API keys.
#   cp .env.example .env

# ─── Air Quality ───────────────────────────────────────
# Free token: https://aqicn.org/data-platform/token/
AQICN_TOKEN=your_aqicn_token_here

# ─── Weather & Wind ────────────────────────────────────
# Free key: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# ─── UV Index ──────────────────────────────────────────
# Free key: https://www.openuv.io/ (note: UV is actually sourced from Open-Meteo;
# this key is optional / unused by default)
OPENUV_API_KEY=your_openuv_key_here

# ─── Traffic ───────────────────────────────────────────
# Free key: https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_key_here

# ─── Open-Meteo & OpenAQ (no key needed) ───────────────
# Used directly in producers without auth

# ─── Kafka ─────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka1:9092,kafka2:9093,kafka3:9094

# ─── HDFS ──────────────────────────────────────────────
HDFS_NAMENODE_HOST=namenode
HDFS_NAMENODE_PORT=9870
HDFS_URL=hdfs://namenode:9000

# ─── Redis ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── ML Inference ──────────────────────────────────────
ML_INFERENCE_URL=http://ml-inference:8001

# ─── Spark ─────────────────────────────────────────────
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_REST_URL=http://spark-master:6066

# ─── Backend ───────────────────────────────────────────
BACKEND_PORT=8000

# ─── Stations (Jabodetabek) ────────────────────────────
STATIONS=jakarta-pusat,jakarta-selatan,jakarta-utara,jakarta-timur,jakarta-barat,depok,tangerang,bekasi,bogor,tangerang-selatan
